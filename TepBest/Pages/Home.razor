@page "/"

@using System.Linq
<PageTitle>TEP Calculator</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-3 pt-6">

    <div class="d-flex align-center justify-center mb-1 gap-3">
        <img src="favicon-32.png" class="tep-title-icon" alt="Convergence of Cyriss logo" />
        <MudText Typo="Typo.h6" Align="Align.Center" Class="tep-title"
                 Style="letter-spacing: 0.25em; font-weight: 800; text-transform: uppercase;">
            TEP Calculator
        </MudText>
        <img src="favicon-32.png" class="tep-title-icon" alt="Convergence of Cyriss logo" />
    </div>
    <MudDivider Class="mb-2" />

    <div class="d-flex justify-end align-center mb-3">
        <MudSwitch @bind-Value="multiTargetMode"
                   @bind-Value:after="OnModeSwitched"
                   Color="Color.Primary"
                   Label="Multi-Target" />
    </div>

    <MudGrid Spacing="16">

        @* LEFT COLUMN: inputs + best allocation *@
        <MudItem xs="12" md="5">

            <MudGrid Justify="Justify.Center" Spacing="3">

                <MudItem xs="6" Class="d-flex flex-column align-center">
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-1">RAT</MudText>
                    <MudNumericField @bind-Value="rat"
                                     @bind-Value:after="Recalculate"
                                     Variant="Variant.Outlined"
                                     Class="square-input"
                                     HideSpinButtons="true"
                                     Min="0" Max="99" />
                </MudItem>

                <MudItem xs="6" Class="d-flex flex-column align-center">
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-1">POW</MudText>
                    <MudNumericField @bind-Value="pow"
                                     @bind-Value:after="Recalculate"
                                     Variant="Variant.Outlined"
                                     Class="square-input"
                                     HideSpinButtons="true"
                                     Min="0" Max="99" />
                </MudItem>

                @if (!multiTargetMode)
                {
                    @* Single-target: TargetRow renders as three MudItems inside this MudGrid *@
                    <TargetRow Target="targets[0]"
                               Index="0"
                               MultiTargetMode="false"
                               ShowRemove="false"
                               OnChanged="EventCallback.Factory.Create(this, Recalculate)" />
                }

            </MudGrid>

            @* Multi-target controls + target cards *@
            @if (multiTargetMode)
            {
                <div class="d-flex align-center gap-2 mt-3 mb-2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add"
                               Disabled="targets.Count >= MaxTargets"
                               OnClick="AddTarget">Add Target</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.RestartAlt"
                               OnClick="ResetTargets">Reset</MudButton>
                </div>

                @for (int i = 0; i < targets.Count; i++)
                {
                    var idx = i;
                    <TargetRow @key="idx"
                               Target="targets[idx]"
                               Index="idx"
                               MultiTargetMode="true"
                               ShowRemove="targets.Count > 1"
                               OnChanged="EventCallback.Factory.Create(this, Recalculate)"
                               OnRemove="EventCallback.Factory.Create(this, () => RemoveTarget(idx))" />
                }
            }

        </MudItem>

        @* RIGHT COLUMN: all allocations table + sort *@
        @if (best is not null)
        {
            <MudItem xs="12" md="7">

                <div class="d-flex align-center mb-2">
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Class="flex-grow-1">
                        Best Allocation
                    </MudText>
                    @if (multiTargetMode)
                    {
                        <div class="d-flex align-center gap-1">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">Tiebreaker</MudText>
                            <MudTooltip Text="When no priority target is set: Most Kills maximises kill probability per target. Most Damage maximises expected damage. Priority targets always optimise for kill chance first."
                                        Placement="Placement.Top" Arrow="true">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                            </MudTooltip>
                            <MudToggleGroup @bind-Value="multiTiebreaker" @bind-Value:after="Recalculate"
                                            T="MultiTiebreaker" SelectionMode="SelectionMode.SingleSelection"
                                            Color="Color.Primary" Size="Size.Small">
                                <MudToggleItem Value="MultiTiebreaker.Kills" Text="Most Kills" />
                                <MudToggleItem Value="MultiTiebreaker.Damage" Text="Most Damage" />
                            </MudToggleGroup>
                        </div>
                    }
                </div>

                <MudPaper Elevation="4" Class="pa-4 mb-5 result-card result-card-total">
                    <MudGrid Justify="Justify.Center" Spacing="1">
                        <MudItem xs="4" Class="d-flex flex-column align-center">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">ATK DICE</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight:800">@best.AttackDice</MudText>
                        </MudItem>
                        <MudItem xs="4" Class="d-flex flex-column align-center">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">DMG DICE</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight:800">@best.DamageDice</MudText>
                        </MudItem>
                        <MudItem xs="4" Class="d-flex flex-column align-center">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">ATTACKS</MudText>
                            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight:800">@best.Attacks</MudText>
                        </MudItem>

                        <MudItem xs="3" Class="d-flex flex-column align-center mt-2">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">@(multiTargetMode ? "AVG" : "HIT")</MudText>
                            <div class="d-flex align-center gap-1">
                                <MudText Typo="Typo.overline" Color="Color.Secondary">
                                    @(multiTargetMode ? "HIT%" : "CHANCE")
                                </MudText>
                                <MudTooltip Text="@(multiTargetMode
                                    ? "Average hit probability across all targets in the line. Each target is rolled independently; lower-DEF targets pull the average up."
                                    : "Probability of hitting the target, rounded to the nearest 0.1%. Snake eyes (all 1s) always miss; boxcars (all 6s) always hit.")"
                                            Placement="Placement.Top" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                </MudTooltip>
                            </div>
                            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight:800">@(multiTargetMode ? FormatHitChance(best.PerTarget.Average(p => p.Hit)) : FormatHitChance(best.PerTarget[0].Hit))</MudText>
                        </MudItem>

                        <MudItem xs="3" Class="d-flex flex-column align-center mt-2">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">@(multiTargetMode ? "TOTAL" : "EXPECTED")</MudText>
                            <div class="d-flex align-center gap-1">
                                <MudText Typo="Typo.overline" Color="Color.Secondary">TOTAL</MudText>
                                <MudTooltip Text="@(multiTargetMode
                                    ? "Sum of expected damage across all targets in the line. Each target uses independent rolls with the same buff dice."
                                    : "Expected Total = Number of Attacks × Chance to Hit × Average Damage per Hit")"
                                            Placement="Placement.Top" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                </MudTooltip>
                            </div>
                            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight:800">@best.ExpectedTotalDamage.ToString("F1")</MudText>
                        </MudItem>

                        <MudItem xs="3" Class="d-flex flex-column align-center mt-2">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">@(multiTargetMode ? "AVG DMG" : "IF ALL")</MudText>
                            <div class="d-flex align-center gap-1">
                                <MudText Typo="Typo.overline" Color="Color.Secondary">@(multiTargetMode ? "EACH" : "HIT")</MudText>
                                <MudTooltip Text="@(multiTargetMode
                                    ? "Average all-hit damage per target = total all-hit damage ÷ number of targets (assumes every attack on every target lands)."
                                    : "If All Hit = Number of Attacks × Average Damage per Hit (assumes every attack lands)")"
                                            Placement="Placement.Top" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                </MudTooltip>
                            </div>
                            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight:800">@(multiTargetMode ? (best.AllHitDamage / targets.Count).ToString("F1") : best.AllHitDamage.ToString("F1"))</MudText>
                        </MudItem>

                        <MudItem xs="3" Class="d-flex flex-column align-center mt-2">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">@(multiTargetMode ? "EXP" : "KILL")</MudText>
                            <div class="d-flex align-center gap-1">
                                <MudText Typo="Typo.overline" Color="Color.Secondary">@(multiTargetMode ? "KILLS" : "CHANCE")</MudText>
                                <MudTooltip Text="@KillTooltip" Placement="Placement.Top" Arrow="true">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                </MudTooltip>
                            </div>
                            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight:800">@FormatExpectedKills(best.ExpectedKills)</MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <MudText Typo="Typo.overline" Color="Color.Secondary" Align="Align.Center" Class="mb-2">
                    All Allocations
                </MudText>

                <MudExpansionPanels Class="mb-3 sort-accordion" Elevation="0">
                    <MudExpansionPanel Text="Advanced Sort" Dense="true" DisableGutters="true">
                        <div class="d-flex flex-column gap-2 pt-2">
                            <div class="d-flex align-center gap-2">
                                <MudText Typo="Typo.overline" Color="Color.Secondary" Style"white-space:nowrap;width:70px">Filter By:</MudText>
                                <MudSelect @bind-Value="sort1" Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                           Class="sort-select" T="string">
                                    @foreach (var opt in Sort1Options)
                                    {
                                        <MudSelectItem Value="@opt">@opt</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <MudText Typo="Typo.overline" Color="Color.Secondary" Style="white-space:nowrap;width:70px">Then:</MudText>
                                <MudSelect @bind-Value="sort2" Dense="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                                           Class="sort-select" T="string">
                                    @foreach (var opt in Sort2Options)
                                    {
                                        <MudSelectItem Value="@opt">@opt</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small" Class="mb-2"
                                       FullWidth="true" OnClick="ResetSort">Set Default</MudButton>
                        </div>
                    </MudExpansionPanel>
                </MudExpansionPanels>

                <MudSimpleTable Dense="true" Hover="true" Class="alloc-table">
                    <thead>
                        <tr>
                            <th class="@ThClass(SortColumns.AttackDice)" @onclick="() => ClickHeader(SortColumns.AttackDice)">ATK@(SortCaret(SortColumns.AttackDice))</th>
                            <th class="@ThClass(SortColumns.DamageDice)" @onclick="() => ClickHeader(SortColumns.DamageDice)">DMG@(SortCaret(SortColumns.DamageDice))</th>
                            <th class="@ThClass(SortColumns.NumAttacks)" @onclick="() => ClickHeader(SortColumns.NumAttacks)">#ATK@(SortCaret(SortColumns.NumAttacks))</th>
                            <th class="@ThClass(SortColumns.HitChance)" @onclick="() => ClickHeader(SortColumns.HitChance)">
                                @if (multiTargetMode)
                                {
                                    <div class="d-flex align-center justify-center gap-1">
                                        AVG HIT%@(SortCaret(SortColumns.HitChance))
                                        <MudTooltip Text="Average hit probability across all targets in the line. Each target is rolled independently." Placement="Placement.Top" Arrow="true">
                                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                        </MudTooltip>
                                    </div>
                                }
                                else
                                {
                                    <span>HIT%@(SortCaret(SortColumns.HitChance))</span>
                                }
                            </th>
                            <th class="@ThClass(SortColumns.AvgDmg)" @onclick="() => ClickHeader(SortColumns.AvgDmg)">
                                @if (multiTargetMode)
                                {
                                    <div class="d-flex align-center justify-center gap-1">
                                        TOTAL@(SortCaret(SortColumns.AvgDmg))
                                        <MudTooltip Text="Sum of expected damage across all targets" Placement="Placement.Top" Arrow="true">
                                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                        </MudTooltip>
                                    </div>
                                }
                                else
                                {
                                    <span>TOTAL@(SortCaret(SortColumns.AvgDmg))</span>
                                }
                            </th>
                            <th class="@ThClass(SortColumns.IfAllHit)" @onclick="() => ClickHeader(SortColumns.IfAllHit)">@(multiTargetMode ? "AVG EACH" : "ALL HIT")@(SortCaret(SortColumns.IfAllHit))</th>
                            <th class="@ThClass(SortColumns.KillChance)" @onclick="() => ClickHeader(SortColumns.KillChance)">
                                <div class="d-flex align-center justify-center gap-1">
                                    @(multiTargetMode ? "~# KILLS" : "KILL%")@(SortCaret(SortColumns.KillChance))
                                    <MudTooltip Text="@KillTooltip" Placement="Placement.Top" Arrow="true">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                    </MudTooltip>
                                </div>
                            </th>
                            @if (multiTargetMode)
                            {
                                <th></th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in SortedAllocations)
                        {
                            var isExpanded = expandedRows.Contains(a);
                            <tr class="@(a == best ? "best-row" : "")">
                                <td>@a.AttackDice</td>
                                <td>@a.DamageDice</td>
                                <td>@a.Attacks</td>
                                <td>@(multiTargetMode ? FormatHitChance(a.PerTarget.Average(p => p.Hit)) : FormatHitChance(a.PerTarget[0].Hit))</td>
                                <td>@a.ExpectedTotalDamage.ToString("F1")</td>
                                <td>@(multiTargetMode ? (a.AllHitDamage / targets.Count).ToString("F1") : a.AllHitDamage.ToString("F1"))</td>
                                <td>@FormatExpectedKills(a.ExpectedKills)</td>
                                @if (multiTargetMode)
                                {
                                    <td>
                                        <MudIconButton Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                                       Size="Size.Small"
                                                       OnClick="() => ToggleExpand(a)" />
                                    </td>
                                }
                            </tr>
                            @if (multiTargetMode && isExpanded)
                            {
                                <tr class="expand-row">
                                    <td colspan="8">
                                        <table class="expand-detail-table">
                                            <thead>
                                                <tr>
                                                    <th>TARGET</th>
                                                    <th>HIT%</th>
                                                    <th>EXPECTED</th>
                                                    <th>ALL HIT</th>
                                                    <th>KILL%</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @for (int ti = 0; ti < targets.Count; ti++)
                                                {
                                                    var pt  = a.PerTarget[ti];
                                                    var tgt = targets[ti];
                                                    <tr>
                                                        <td>
                                                            @(string.IsNullOrWhiteSpace(tgt.Label) ? $"Target {ti + 1}" : tgt.Label)
                                                            @if (tgt.IsPriority) { <span class="priority-star">★</span> }
                                                        </td>
                                                        <td>@FormatHitChance(pt.Hit)</td>
                                                        <td>@pt.Expected.ToString("F1")</td>
                                                        <td>@pt.AllHit.ToString("F1")</td>
                                                        <td>@FormatHitChance(pt.Kill)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </MudSimpleTable>

            </MudItem>
        }

    </MudGrid>

    <MudDivider Class="mt-6 mb-3" />
    <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Class="mb-4">
        By <MudLink Href="https://github.com/marquisdan" Target="_blank" Color="Color.Secondary" Typo="Typo.caption">marquisdan</MudLink>
        &nbsp;·&nbsp;
        <MudLink Href="https://github.com/marquisdan/TEP-Calculator" Target="_blank" Color="Color.Secondary" Typo="Typo.caption">View on GitHub</MudLink>
        &nbsp;·&nbsp;
        <MudLink Href="https://ko-fi.com/marquisdan" Target="_blank" Color="Color.Secondary" Typo="Typo.caption">☕ Support via Ko-fi</MudLink>
    </MudText>

</MudContainer>

@code {
    private const int MaxTargets = 10;

    private int rat = 5;
    private int pow = 11;

    private List<Target> targets = [new Target()];
    private bool             multiTargetMode  = false;
    private MultiTiebreaker  multiTiebreaker  = MultiTiebreaker.Kills;

    private List<BuffAllocation> allocations = new();
    private BuffAllocation? best;
    private HashSet<BuffAllocation> expandedRows = new();

    private static readonly string[] Sort1Options = SortColumns.Sort1Options;
    private static readonly string[] Sort2Options = SortColumns.Sort2Options;

    private string sort1    = SortColumns.KillChance;
    private bool   sort1Asc = false;
    private string sort2    = SortColumns.None;

    // ── Display helpers ──────────────────────────────────────────────────────

    private string TargetLabel(int i)
    {
        var t = targets[i];
        return string.IsNullOrWhiteSpace(t.Label) ? $"Target {i + 1}" : t.Label;
    }

    private string KillTooltip => multiTargetMode
        ? "Expected number of kills = sum of each target's individual kill probability. Independent rolls mean this can exceed 1 (e.g. 1.8 means you expect to kill nearly 2 targets)."
        : "Exact probability your total damage equals or exceeds the target's remaining boxes, accounting for hit probability and damage variability across all attacks.";

    private string FormatExpectedKills(double v) =>
        multiTargetMode ? v.ToString("F2") : FormatHitChance(v);

    private static string FormatHitChance(double chance)
    {
        if (chance >= 0.9995) return ">99.9%";
        if (chance == 0)      return "0%";
        if (chance <= 0.0005) return "<0.1%";
        return chance.ToString("P1");
    }

    // ── Sort ─────────────────────────────────────────────────────────────────

    private IEnumerable<BuffAllocation> SortedAllocations
    {
        get
        {
            var ordered = sort1Asc
                ? allocations.OrderBy(SortKey(sort1))
                : allocations.OrderByDescending(SortKey(sort1));
            return sort2 != SortColumns.None
                ? ordered.ThenByDescending(SortKey(sort2))
                : ordered;
        }
    }

    private Func<BuffAllocation, double> SortKey(string col) => col switch
    {
        var c when c == SortColumns.AttackDice => a => a.AttackDice,
        var c when c == SortColumns.DamageDice => a => a.DamageDice,
        var c when c == SortColumns.NumAttacks => a => a.Attacks,
        var c when c == SortColumns.HitChance  => a => Math.Round(a.PerTarget[0].Hit * 100, 1),
        var c when c == SortColumns.AvgDmg     => a => Math.Round(a.ExpectedTotalDamage, 1),
        var c when c == SortColumns.IfAllHit   => a => Math.Round(multiTargetMode ? a.AllHitDamage / targets.Count : a.AllHitDamage, 1),
        var c when c == SortColumns.KillChance => a => Math.Round(a.ExpectedKills, 4),
        _                                      => a => 0
    };

    private void ResetSort() { sort1 = SortColumns.KillChance; sort1Asc = false; sort2 = SortColumns.None; }

    private void ClickHeader(string col)
    {
        if (sort1 == col) sort1Asc = !sort1Asc;
        else { sort1 = col; sort1Asc = false; }
    }

    private string ThClass(string col)   => sort1 == col ? "th-sort th-sort-active" : "th-sort";
    private string SortCaret(string col)  => sort1 == col ? (sort1Asc ? " ▲" : " ▼") : "";

    // ── Target management ────────────────────────────────────────────────────

    private void AddTarget()
    {
        if (targets.Count < MaxTargets)
        {
            targets.Add(new Target());
            Recalculate();
        }
    }

    private void RemoveTarget(int i)
    {
        if (targets.Count > 1)
        {
            targets.RemoveAt(i);
            Recalculate();
        }
    }

    private void ResetTargets()
    {
        targets = [new Target()];
        expandedRows.Clear();
        Recalculate();
    }

    private void OnModeSwitched() { ResetTargets(); ResetSort(); }

    private void ToggleExpand(BuffAllocation a)
    {
        if (!expandedRows.Remove(a)) expandedRows.Add(a);
    }

    // ── Data model ───────────────────────────────────────────────────────────

    private record PerTargetStats(double Hit, double Expected, double AllHit, double Kill);

    private record BuffAllocation(
        int AttackBuff, int DamageBuff, int AttacksBuff,
        IReadOnlyList<PerTargetStats> PerTarget,
        double ExpectedTotalDamage, double AllHitDamage, double ExpectedKills)
    {
        public int AttackDice => 2 + AttackBuff;
        public int DamageDice => 2 + DamageBuff;
        public int Attacks    => 2 + AttacksBuff;
    }

    // ── Recalculate ──────────────────────────────────────────────────────────

    protected override void OnInitialized() => Recalculate();

    private void Recalculate()
    {
        allocations.Clear();
        expandedRows.Clear();

        for (int a = 0; a <= 3; a++)
        for (int d = 0; d <= 3 - a; d++)
        {
            int c          = 3 - a - d;
            int attackDice = 2 + a;
            int damageDice = 2 + d;
            int numAttacks = 2 + c;

            var perTarget  = new List<PerTargetStats>(targets.Count);
            double aggExpected = 0, aggAllHit = 0, expKills = 0;

            foreach (var t in targets)
            {
                double hit      = HitProbability(attackDice, t.Def - rat);
                double dmgPH    = ExpectedDamagePerHit(damageDice, pow - t.Arm);
                double expected = numAttacks * hit * dmgPH;
                double allHit   = numAttacks * dmgPH;
                double kill     = ChanceToKill(attackDice, damageDice, numAttacks, t.Def - rat, pow - t.Arm, t.Boxes);

                perTarget.Add(new PerTargetStats(hit, expected, allHit, kill));
                aggExpected += expected;
                aggAllHit   += allHit;
                expKills    += kill;
            }

            allocations.Add(new BuffAllocation(a, d, c, perTarget, aggExpected, aggAllHit, expKills));
        }

        allocations = allocations.OrderByDescending(x => x.ExpectedTotalDamage).ToList();
        best = PickBest();
    }

    private BuffAllocation? PickBest()
    {
        if (allocations.Count == 0) return null;

        var priorityIndices = targets
            .Select((t, i) => (t, i))
            .Where(x => x.t.IsPriority)
            .Select(x => x.i)
            .ToList();

        if (priorityIndices.Count > 0)
        {
            // Priority targets: maximise kill chance on them first (directly rewards
            // attack dice against high-DEF targets), then aggregate as tiebreaker.
            return allocations
                .OrderByDescending(a => priorityIndices.Sum(i => a.PerTarget[i].Kill))
                .ThenByDescending(a => a.ExpectedTotalDamage)
                .First();
        }

        // No priority targets, single effective target: maximise kill chance.
        if (!multiTargetMode || targets.Count == 1)
        {
            return allocations
                .OrderByDescending(a => a.ExpectedKills)
                .ThenByDescending(a => a.ExpectedTotalDamage)
                .First();
        }

        // Multiple targets, no priority: user-selected tiebreaker
        return multiTiebreaker == MultiTiebreaker.Kills
            ? allocations.OrderByDescending(a => a.ExpectedKills).ThenByDescending(a => a.ExpectedTotalDamage).First()
            : allocations.OrderByDescending(a => a.ExpectedTotalDamage).ThenByDescending(a => a.ExpectedKills).First();
    }

    // ── Math helpers ─────────────────────────────────────────────────────────

    // P(total damage dealt >= boxes) across numAttacks independent attacks
    private static double ChanceToKill(int attackDice, int damageDice, int numAttacks,
                                       int defThreshold, int armBonus, int boxes)
    {
        double hitChance = HitProbability(attackDice, defThreshold);
        double[] dicePmf = DicePmf(damageDice);

        // Build single-attack damage PMF (0 = miss; otherwise clamped damage dice sum + armBonus)
        int maxSingleDmg = dicePmf.Length - 1 + Math.Max(armBonus, 0);
        double[] singlePmf = new double[Math.Max(maxSingleDmg + 1, 1)];
        singlePmf[0] += 1.0 - hitChance; // miss contributes 0 damage

        for (int s = 0; s < dicePmf.Length; s++)
        {
            if (dicePmf[s] == 0) continue;
            int dmg = Math.Max(s + armBonus, 0);
            if (dmg >= singlePmf.Length)
            {
                var expanded = new double[dmg + 1];
                singlePmf.CopyTo(expanded, 0);
                singlePmf = expanded;
            }
            singlePmf[dmg] += hitChance * dicePmf[s];
        }

        // Convolve numAttacks times to get total damage PMF
        double[] totalPmf = [1.0];
        for (int n = 0; n < numAttacks; n++)
        {
            double[] next = new double[totalPmf.Length + singlePmf.Length - 1];
            for (int i = 0; i < totalPmf.Length; i++)
            {
                if (totalPmf[i] == 0) continue;
                for (int j = 0; j < singlePmf.Length; j++)
                    next[i + j] += totalPmf[i] * singlePmf[j];
            }
            totalPmf = next;
        }

        double prob = 0;
        for (int k = boxes; k < totalPmf.Length; k++)
            prob += totalPmf[k];
        return Math.Min(prob, 1.0);
    }

    // P(sum of nDice d6 >= threshold), with Warmachine special rules:
    //   All 1s always miss (snake eyes), all 6s always hit (boxcars)
    private static double HitProbability(int nDice, int threshold)
    {
        double allOnes  = Math.Pow(1.0 / 6.0, nDice);
        double allSixes = Math.Pow(1.0 / 6.0, nDice);

        if (threshold > 6 * nDice) return allSixes;
        if (threshold <= nDice)    return 1.0 - allOnes;

        double[] pmf = DicePmf(nDice);
        double prob = 0;
        for (int s = threshold; s < pmf.Length; s++)
            prob += pmf[s];
        return prob;
    }

    // E[max(sum of nDice d6 + bonus, 0)]
    private static double ExpectedDamagePerHit(int nDice, int bonus)
    {
        double[] pmf = DicePmf(nDice);
        double expected = 0;
        for (int s = 0; s < pmf.Length; s++)
            expected += pmf[s] * Math.Max(s + bonus, 0);
        return expected;
    }

    // Returns PMF array where index = dice sum, value = probability
    private static double[] DicePmf(int nDice)
    {
        double[] pmf = new double[7];
        for (int f = 1; f <= 6; f++)
            pmf[f] = 1.0 / 6.0;

        for (int d = 2; d <= nDice; d++)
        {
            double[] next = new double[6 * d + 1];
            for (int s = 0; s < pmf.Length; s++)
            {
                if (pmf[s] == 0) continue;
                for (int f = 1; f <= 6; f++)
                    next[s + f] += pmf[s] * (1.0 / 6.0);
            }
            pmf = next;
        }
        return pmf;
    }
}


